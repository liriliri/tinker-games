{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "skipLibCheck": true,
    "strict": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "packages/tinker-*/src/**/*.ts",
    "node_modules/tinker-api-types/tinker.d.ts"
  ],
  "exclude": [
    "**/references/**",
    "**/dist/**"
  ]
}